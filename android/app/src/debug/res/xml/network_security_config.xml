<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust system certs -->
            <certificates src="system"/>

            <!-- Trust user-installed certs (IMPORTANT) -->
            <certificates src="user"/>
        </trust-anchors>
    </base-config>

</network-security-config>